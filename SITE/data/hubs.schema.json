{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://procederfilosofico.com.br/schemas/hubs.schema.json",
  "title": "Proceder Filosófico HUB Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "hubs"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "hubs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "slug",
          "type",
          "title",
          "label",
          "description",
          "intro",
          "postSlugs",
          "metaTitle",
          "metaDescription",
          "image",
          "updatedISO"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
          "type": { "enum": ["category", "curated"] },
          "title": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "intro": { "type": "string", "minLength": 1 },
          "tag": { "type": "string", "minLength": 1 },
          "postSlugs": {
            "type": "array",
            "uniqueItems": true,
            "items": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" }
          },
          "metaTitle": { "type": "string", "minLength": 1 },
          "metaDescription": { "type": "string", "minLength": 1 },
          "image": { "type": "string", "minLength": 1 },
          "updatedISO": { "type": "string", "format": "date" }
        },
        "allOf": [
          {
            "if": { "properties": { "type": { "const": "category" } } },
            "then": { "required": ["tag"] }
          }
        ]
      }
    }
  }
}
